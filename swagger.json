  "components": {
    "schemas": {
      "Pedido": {
        "type": "object",
        "properties": {
          "ped_id": { 
            "type": "string",
            "description": "id del pedido" 
          },
          "ped_fecha": { 
            "type": "string",
            "format": "date",
            "description": "fecha del pedido" 
          },
          "ped_metodo_pago": { 
            "type": "string",
            "description": "método de pago del pedido" 
          },
          "ped_estado_entrega": { 
            "type": "string",
            "description": "estado de entrega del pedido" 
          },
          "ped_total": { 
            "type": "number",
            "format": "float",
            "description": "total del pedido" 
          },
          "ped_cli_id_fk": { 
            "type": "string",
            "description": "id del cliente del pedido" 
          },
          "ped_usu_id_fk": { 
            "type": "string",
            "description": "id del usuario del pedido" 
          }
        }
      },
      "Usuario": {
      "type": "object",
      "properties": {
        "usu_id": { "type": "string", "description": "id del usuario" },
        "usu_nombre": { "type": "string", "description": "nombre del usuario" },
        "usu_rol": { "type": "string", "description": "rol del usuario" },
        "usu_correo": { "type": "string", "format": "email", "description": "correo del usuario" },
        "usu_contrasena": { "type": "string", "description": "contraseña del usuario" },
        "usu_estado": { "type": "string", "description": "estado del usuario" },
        "usu_ultimo_acceso": { "type": "string", "format": "date-time", "description": "último acceso del usuario" }
        }
      },
      "Sesion":{
        "type": "object",
        "properties": {
          "ses_id": { "type": "string", "description": "id de la sesión" },
          "ses_usu_id_fk": { "type": "string", "description": "id del usuario de la sesión" },
          "ses_fecha_inicio": { "type": "string", "format": "date-time", "description": "fecha de inicio de la sesión" },
          "ses_fecha_fin": { "type": "string", "format": "date-time", "description": "fecha de fin de la sesión" },
          "ses_ip":{
            "type": "string",
            "description": "dirección IP de la sesión"
          },
          "ses_activa":{
            "type": "interger",
            "description": "indica si la sesión está activa"
          }
        }
      },
      "reporte":{
        "type": "object",
        "properties": {
          "rep_id": { "type": "string", "description": "id del reporte" },
          "rep_fecha": { "type": "string", "format": "date-time", "description": "fecha del reporte" },
          "rep_tipo": { "type": "string", "description": "tipo del reporte" },
          "rep_parametros": { "type": "string", "description": "parámetros del reporte" },
          "rep_usu_id_fk": { "type": "string", "description": "id del usuario del reporte" },
          "rep_resultados": { "type": "string", "description": "resultados del reporte" }
        }
        },
        "Cliente":{
          "type": "object",
          "properties": {
            "cli_id": { "type": "string", "description": "id del cliente" },
            "cli_nombre": { "type": "string", "description": "nombre del cliente" },
            "cli_correo": { "type": "string", "format": "email", "description": "correo del cliente" },
            "cli_telefono": { "type": "string", "description": "teléfono del cliente" },
            "cli_direccion": { "type": "string", "description": "dirección del cliente" },
            "cli_tipo_documento": { "type": "string", "description": "tipo de documento del cliente" }
        }
        },
        "Kardex":{
          "type": "object",
          "properties": {
            "kar_id": { "type": "string", "description": "id del kardex" },
            "kar_fecha": { "type": "string", "format": "date-time", "description": "fecha del kardex" },
            "kar_cantidad": { "type": "number", "format": "float", "description": "cantidad del kardex" },
            "kar_pro_id_fk": { "type": "string", "description": "id del producto del kardex" },
            "kar_lot_id_fk": { "type": "string", "description": "id del lote del kardex" },
            "kar_inm_id_fk": { "type": "string", "description": "id del inventario del kardex" },
            "kar_tipo": { "type": "string", "description": "tipo del kardex (entrada o salida)" },
            "kar_saldo_anterior": { "type": "number", "format": "float", "description": "saldo anterior del kardex" },
            "kar_saldo_actual": { "type": "number", "format": "float", "description": "saldo actual del kardex" },
            "kar_costo_unitario": { "type": "number", "format": "float", "description": "costo unitario del kardex" },
            "kar_costo_total": { "type": "number", "format": "float", "description": "costo total del kardex" }
        }
        }
    }
  }
